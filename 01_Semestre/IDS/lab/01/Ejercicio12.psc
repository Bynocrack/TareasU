Algoritmo Ejercicio12
	Definir pGinecologia, pPediatria, pTraumatologia, pGeneral como reales
	
	Escribir "Digite el presupuesto general:"
	Leer pGeneral
	
	pGinecologia = pGeneral*0.4
	pPediatria = pGeneral*0.3
	pTraumatologia = pGeneral*0.3
	
	Escribir "El monto de ginecología es de ", pGinecologia
	Escribir "El monto de pediatría es de ", pPediatria
	Escribir "El monto de traumatología es de ", pTraumatologia
FinAlgoritmo
