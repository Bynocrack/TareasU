Algoritmo Ejercicio01
	definir nombre como caracter
	definir precio Como Real
	definir cantidad como entero
	Escribir "Como se llama el producto? "
	leer nombre
	Escribir "Cuanto cuesta? "
	leer precio
	Escribir "Cuantos son? "
	leer cantidad
	
	costo = precio*cantidad
	
	Escribir "Comprar ", cantidad, " de ", nombre, " cuesta ", costo	
	
FinAlgoritmo
